{
  "name": "@terangatable/database",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": ["dist", "prisma", "src"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:seed": "ts-node --project ./prisma/tsconfig.json ./prisma/seed.ts",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "generate": "prisma generate --schema=./prisma/schema.prisma",
    "migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "seed": "ts-node --project ./prisma/tsconfig.json ./prisma/seed.ts",
    "studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:reset": "prisma migrate reset --force --schema=./prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "bcrypt": "^5.1.1",
    "prisma": "^5.13.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}

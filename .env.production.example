# ═══════════════════════════════════════════════════════════════════
# TérangaTable — Production Environment
# Copy to .env.production and fill in all CHANGE_ME values
# Generate secrets: openssl rand -base64 32
# ═══════════════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────────────────
# Used by Docker service AND the API DATABASE_URL
POSTGRES_USER=terangatable
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_URL=postgresql://terangatable:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/terangatable

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── RabbitMQ ─────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=terangatable
RABBITMQ_DEFAULT_PASS=CHANGE_ME_STRONG_MQ_PASSWORD
RABBITMQ_URL=amqp://terangatable:CHANGE_ME_STRONG_MQ_PASSWORD@rabbitmq:5672

# ── JWT (generate each with: openssl rand -base64 48) ────────────────
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_DIFFERENT
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── MinIO (S3-compatible) ─────────────────────────────────────────────
# MINIO_ROOT_USER must match S3_ACCESS_KEY
# MINIO_ROOT_PASSWORD must match S3_SECRET_KEY
MINIO_ROOT_USER=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_SECRET_KEY
S3_ENDPOINT=http://minio:9000
S3_BUCKET=terangatable
S3_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
S3_REGION=eu-west-1
# Public URL used to build image URLs returned to the browser.
# Point this to the nginx /minio proxy (see nginx.vhost.conf).
S3_PUBLIC_URL=https://api.terangatable.cloud/minio

# ── Meilisearch ───────────────────────────────────────────────────────
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# ── SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME_EMAIL@gmail.com
SMTP_PASS=CHANGE_ME_APP_PASSWORD
SMTP_FROM=noreply@terangatable.cloud

# ── Application ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://terangatable.cloud
PLATFORM_DOMAIN=terangatable.cloud
CDN_BASE_URL=https://terangatable.cloud/cdn

# ── Next.js public vars (baked into the client bundle at build time) ──
# These are also passed as Docker build args in docker-compose.prod.yml
NEXT_PUBLIC_API_URL=https://api.terangatable.cloud/v1
NEXT_PUBLIC_WS_URL=wss://api.terangatable.cloud
